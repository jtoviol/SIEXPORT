# DataDownload — Sistema de exportación
# Copiar a .env y ajustar valores

# Modo de operación
USE_MOCK=false                          # true = datos falsos; false = SQL Server real
LIMITE_REGISTROS=25                    # tope NUM_REGISTRO para pruebas

# SQL Server (solo si USE_MOCK=false)
DB_HOST=10.x.x.x
DB_PORT=1433
DB_NAME=seragil
DB_USER=sa
DB_PASSWORD=cambiar-en-.env-real
DB_DRIVER=ODBC Driver 17 for SQL Server

# SQL Server sibacom — módulo Caracterización Familiar (otro servidor)
DB_HOST_SIBACOM=10.x.x.x
DB_PORT_SIBACOM=1433
DB_NAME_SIBACOM=sibacom
DB_USER_SIBACOM=usuario
DB_PASSWORD_SIBACOM=cambiar-en-.env-real

# Paralelismo
LOTE_WORKERS=2                         # lotes simultáneos (1 = secuencial, máx recomendado: 3)

# Almacenamiento
DATA_DIR=./data                        # carpeta donde se guardan los .zip generados
TEMPLATES_DIR=./src/efdi/templates     # ruta a las plantillas

# API
API_HOST=0.0.0.0
API_PORT=8765
LOG_LEVEL=INFO
